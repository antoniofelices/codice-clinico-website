---
interface Props {
  content: string
  theme?: "default" | "on-dark"
  class?: string
}

const { content, theme = "default", class: extraClass = "" } = Astro.props
---

<p
  class:list={[
    "mb-4 font-semibold text-3xl md:text-5xl lg:text-7xl 2xl:text-9xl",
    theme === "on-dark" && "text-cream-50/80",
    extraClass,
  ]}
>
  {content}
</p>
