---
import type { AstroComponent } from "@lucide/astro"

interface Props {
  icon?: AstroComponent
  iconDark?: boolean
  gradientBar?: boolean
  class?: string
}

const {
  icon: IconComponent,
  iconDark = false,
  gradientBar = false,
  class: extraClass = "",
} = Astro.props
---

<div
  class:list={[
    "bg-cream-50 rounded-3xl p-8 border border-gray-50 shadow-card overflow-hidden relative",
    extraClass,
  ]}
>
  {
    gradientBar && (
      <div class="absolute top-0 left-0 right-0 h-1 bg-linear-to-r from-indigo-500 to-sky-500" />
    )
  }
  {
    IconComponent && (
      <div
        class:list={[
          "w-11 h-11 rounded-2xl flex items-center justify-center mb-6",
          iconDark
            ? "bg-indigo-800 text-sky-500"
            : "bg-indigo-50 text-indigo-500",
        ]}
      >
        <IconComponent class="w-5 h-5" />
      </div>
    )
  }
  <slot />
</div>
