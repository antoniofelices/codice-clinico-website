---
interface Props {
  markerSingleLine?: boolean
  variant?: "default" | "dark"
  class?: string
}
const {
  markerSingleLine = false,
  variant = "default",
  class: extraClass = "",
} = Astro.props

const numColor = {
  default: "before:text-m-indigo-500",
  dark: "before:text-m-sky-500",
}

const borderColor = {
  default: "border-m-gray-300",
  dark: "border-white/10",
}
---

{
  markerSingleLine ? (
    <li
      class:list={[
        "list-none grid gap-5 border-l-2 pl-5 py-6",
        "before:content-[counter(list-item,decimal-leading-zero)] before:font-mono before:text-sm before:pt-0.5 before:shrink-0",
        numColor[variant],
        borderColor[variant],
        extraClass,
      ]}
      style="counter-increment: list-item;"
    >
      <div>
        <slot />
      </div>
    </li>
  ) : (
    <li
      class:list={[
        "list-none grid gap-5 border-t-2 pt-6 pb-6",
        "before:block before:content-[counter(list-item,decimal-leading-zero)] before:font-mono before:text-sm before:mb-3",
        numColor[variant],
        borderColor[variant],
        extraClass,
      ]}
      style="grid-template-columns: auto 1fr; counter-increment: list-item;"
    >
      <div>
        <slot />
      </div>
    </li>
  )
}
