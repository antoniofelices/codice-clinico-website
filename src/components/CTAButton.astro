---
interface Props {
  href: string
  variant?: "primary" | "secondary" | "outline" | "white"
  size?: "xs" | "sm" | "md" | "lg"
  class?: string
}

const {
  href,
  variant = "primary",
  size = "md",
  class: extraClass = "",
} = Astro.props

const variantClasses = {
  primary: "bg-m-blue-500 text-white hover:bg-m-blue-700",
  secondary: "bg-m-sky-500 text-white hover:bg-m-blue-500",
  outline:
    "border-2 border-m-beige-500 text-m-blue-500 hover:bg-m-blue-500 hover:text-white",
  white: "bg-white text-m-blue-500 hover:bg-m-blue-50",
}

const sizeClasses = {
  xs: "px-4 py-1 text-xs",
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-base",
  lg: "px-8 py-4 text-lg",
}
---

<a
  href={href}
  class={`inline-block rounded-full transition-colors shadow-sm ${variantClasses[variant]} ${sizeClasses[size]} ${extraClass}`}
>
  <slot />
</a>
