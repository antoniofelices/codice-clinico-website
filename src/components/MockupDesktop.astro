---

---

<!-- Desktop dashboard -->
<div
  class="hidden md:grid rounded-3xl shadow-lg border border-white/70 overflow-hidden bg-white"
  style="grid-template-columns: 218px 1fr 280px; height: 540px;"
>
  <!-- Sidebar -->
  <aside
    class="bg-indigo-950 text-cream-50 p-5 flex flex-col gap-1.5 overflow-hidden"
  >
    <div class="flex flex-col mb-5 ml-1.5 mt-1">
      <span
        class="font-extrabold text-2xl tracking-tight text-cream-50 leading-none"
      >
        c<span class="text-sky-500">ó</span>dice
      </span>
      <span
        class="font-mono text-[8.5px] tracking-[0.36em] uppercase text-cream-50/50 mt-0.5"
        >clínico</span
      >
    </div>
    <div
      class="font-mono text-[9.5px] tracking-widest uppercase text-white/40 mx-2 mt-4 mb-1.5"
    >
      Clínico
    </div>
    <div
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-[13.5px] text-white"
      style="background: rgba(93,196,247,0.16);"
    >
      <svg
        class="w-4 h-4 text-sky-500 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><rect x="3" y="4" width="18" height="18" rx="2"></rect><path
          d="M16 2v4M8 2v4M3 10h18"></path></svg
      >
      Agenda
    </div>
    <div
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-[13.5px] text-white/70"
    >
      <svg
        class="w-4 h-4 opacity-80 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16M9 7h6M9 11h6M9 15h4"
        ></path></svg
      >
      Historias clínicas
    </div>
    <div
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-[13.5px] text-white/70"
    >
      <svg
        class="w-4 h-4 opacity-80 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><circle cx="9" cy="8" r="3"></circle><path
          d="M3 20a6 6 0 0 1 12 0M16 11l2 2 4-4"></path></svg
      >
      Pacientes
    </div>
    <div
      class="font-mono text-[9.5px] tracking-widest uppercase text-white/40 mx-2 mt-4 mb-1.5"
    >
      Organización
    </div>
    <div
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-[13.5px] text-white/70"
    >
      <svg
        class="w-4 h-4 opacity-80 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><path d="M9 3H4v5M15 3h5v5M9 21H4v-5M15 21h5v-5"></path></svg
      >
      Consultorios
    </div>
    <div
      class="flex items-center gap-3 px-3 py-2 rounded-lg text-[13.5px] text-white/70"
    >
      <svg
        class="w-4 h-4 opacity-80 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><circle cx="12" cy="8" r="4"></circle><path d="M5 21a7 7 0 0 1 14 0"
        ></path></svg
      >
      Equipo
    </div>
    <div
      class="mt-auto flex items-center gap-2.5 pt-2.5 border-t"
      style="border-color: rgba(255,255,255,0.08);"
    >
      <div
        class="w-8 h-8 rounded-full shrink-0"
        style="background: linear-gradient(135deg, #5dc4f7, #212163);"
      >
      </div>
      <div>
        <div class="text-[12.5px] font-semibold">Dra. Rojas</div>
        <div class="text-[10.5px] text-white/50">Cardiología</div>
      </div>
    </div>
  </aside>

  <!-- Main panel -->
  <div class="flex flex-col" style="background: #f7f8fb;">
    <div
      class="flex items-center gap-3.5 px-6 py-4 border-b border-gray-50 bg-white"
    >
      <div>
        <div class="text-base font-bold tracking-tight">Agenda</div>
        <div class="text-xs text-gray-500 font-medium">
          Lunes 1 de junio · 8 citas
        </div>
      </div>
      <div
        class="ml-auto flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs text-gray-400 min-w-37.5"
        style="background: #f1f2f6;"
      >
        <svg
          class="w-3 h-3 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4-4"
          ></path></svg
        >
        Buscar paciente
      </div>
      <div
        class="flex items-center gap-1.5 bg-indigo-500 text-white text-xs font-semibold px-3 py-1.5 rounded-lg"
      >
        <svg
          class="w-3 h-3 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg
        >
        Nueva cita
      </div>
    </div>
    <div class="p-6 overflow-hidden flex-1">
      <div style="display: grid; grid-template-columns: 46px 1fr;">
        {
          [
            {
              time: "09:00",
              name: "Mateo Salas",
              meta: "Control · 30 min",
              sky: false,
            },
            {
              time: "10:00",
              name: "Lucía Fernández",
              meta: "Primera consulta · 45 min",
              sky: true,
            },
            {
              time: "11:00",
              name: "Carlos Medina",
              meta: "Resultados · 20 min",
              sky: false,
            },
            { time: "12:00", name: "", meta: "", sky: false },
          ].map(({ time, name, meta, sky }) => (
            <>
              <div class="font-mono text-[11px] text-gray-400 pt-0.5 pr-3">
                {time}
              </div>
              <div class="border-t border-dashed border-gray-50 pt-1 pb-4">
                {name && (
                  <div
                    class="rounded-xl p-2.5"
                    style={
                      sky
                        ? "border-left: 3px solid var(--color-sky-500); background: rgba(93,196,247,0.13);"
                        : "border-left: 3px solid var(--color-indigo-500); background: rgba(33,33,99,0.06);"
                    }
                  >
                    <div class="text-[13px] font-semibold">{name}</div>
                    <div class="text-[11.5px] text-gray-500 mt-0.5">
                      {meta}
                    </div>
                  </div>
                )}
              </div>
            </>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Right patient panel -->
  <aside
    class="bg-white border-l border-gray-50 p-5 flex flex-col gap-3.5 overflow-hidden"
  >
    <div
      class="font-mono text-[9.5px] tracking-[0.16em] uppercase text-gray-400"
    >
      Próximo paciente
    </div>
    <div class="flex items-center gap-3">
      <div
        class="w-11 h-11 rounded-xl shrink-0"
        style="background: linear-gradient(135deg, #b9e6fb, #5dc4f7);"
      >
      </div>
      <div>
        <div class="text-base font-bold tracking-tight">Lucía Fernández</div>
        <div class="text-xs text-gray-500">34 años · HC-02841</div>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-2">
      {
        [
          { label: "Presión", value: "118/76", unit: "" },
          { label: "FC", value: "72", unit: "bpm" },
          { label: "Peso", value: "61", unit: "kg" },
          { label: "Talla", value: "1.65", unit: "m" },
        ].map(({ label, value, unit }) => (
          <div class="rounded-xl p-2.5" style="background: #f7f8fb;">
            <div class="text-[10px] text-gray-400 uppercase tracking-wide">
              {label}
            </div>
            <div class="text-base font-bold tracking-tight">
              {value}
              {unit && (
                <span class="text-[10px] font-medium text-gray-500">
                  {" "}
                  {unit}
                </span>
              )}
            </div>
          </div>
        ))
      }
    </div>
    <div
      class="font-mono text-[9.5px] tracking-[0.16em] uppercase text-gray-400"
    >
      Evolución reciente
    </div>
    <div class="flex flex-col">
      {
        [
          {
            title: "Electrocardiograma",
            date: "12 may · Dra. Rojas",
            dot: "indigo",
          },
          {
            title: "Analítica completa",
            date: "28 abr · Laboratorio",
            dot: "sky",
          },
          {
            title: "Primera consulta",
            date: "14 abr · Dra. Rojas",
            dot: "indigo",
          },
        ].map(({ title, date, dot }) => (
          <div class="flex gap-2.5 py-2 border-t border-gray-50">
            <div
              class:list={[
                "w-2 h-2 rounded-full mt-1.5 shrink-0",
                dot === "indigo" ? "bg-indigo-500" : "bg-sky-500",
              ]}
            />
            <div>
              <div class="text-[12.5px] font-semibold">{title}</div>
              <div class="text-[11px] text-gray-500">{date}</div>
            </div>
          </div>
        ))
      }
    </div>
  </aside>
</div>

<!-- Mobile fallback -->
<div
  class="md:hidden rounded-3xl shadow-md border border-gray-50 bg-white px-6 py-8 text-center"
>
  <p class="text-gray-500 text-sm mb-0">
    Accede desde cualquier dispositivo — agenda, historias clínicas y equipo en
    un solo lugar.
  </p>
</div>
