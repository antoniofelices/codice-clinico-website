---
interface Props {
  text: string
  includeIcon?: boolean
}
const { text, includeIcon = true } = Astro.props
---

<li class="my-4">
  <div
    class="flex items-start gap-4 bg-white rounded-xl p-4 shadow-sm border border-m-gray-100"
  >
    {
      includeIcon && (
        <div>
          <div class="w-8 h-8 bg-m-blue-500 text-white rounded-full flex items-center justify-center mt-0.5">
            <svg
              class="w-3 h-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M5 13l4 4L19 7"
              />
            </svg>
          </div>
        </div>
      )
    }
    <span>{text}</span>
  </div>
</li>
