---
import Button from "@components/Button.astro"
import MainMenu from "./MenuMain.astro"
import Logo from "./Logo.astro"
---

<header
  class="sticky top-0 z-50 border-b border-m-gray-50"
  style="background: rgba(245,241,232,0.78); backdrop-filter: saturate(180%) blur(16px);"
>
  <div class="container flex items-center justify-between h-16 gap-8">
    <a href="/" aria-label="Inicio" class="shrink-0">
      <Logo />
    </a>

    <div id="desktop-nav" class="hidden lg:flex items-center flex-1">
      <MainMenu />
    </div>

    <div class="flex items-center gap-3">
      <Button href="/solicita-demo" size="xs" variant="primary">
        Solicita una demo
      </Button>
      <button
        id="mobile-menu-btn"
        class="p-2 lg:hidden text-m-indigo-500"
        type="button"
        aria-label="Acceso Menú"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="absolute z-20 top-5 right-5 hidden"
          id="icon-close"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
        <svg
          width="24"
          height="18"
          viewBox="0 0 24 18"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          aria-hidden="true"
          class="open"
          id="icon-open"
        >
          <path d="M0 0h24v2H0zM0 8h20v2H0zM0 16h16v2H0z"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-nav"
    class="hidden lg:hidden border-t border-m-gray-50"
    style="background: rgba(245,241,232,0.95);"
  >
    <div class="container py-6">
      <MainMenu />
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn")
    const mobileNav = document.getElementById("mobile-nav")
    const iconOpen = document.getElementById("icon-open")
    const iconClose = document.getElementById("icon-close")

    btn?.addEventListener("click", () => {
      const isOpen = !mobileNav?.classList.contains("hidden")
      mobileNav?.classList.toggle("hidden", isOpen)
      iconOpen?.classList.toggle("hidden", !isOpen)
      iconClose?.classList.toggle("hidden", isOpen)
      btn?.classList.toggle("navigation-open", !isOpen)
    })
  }

  document.addEventListener("astro:page-load", initMobileMenu)
</script>
