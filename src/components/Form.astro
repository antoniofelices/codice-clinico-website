---

---

<div class="form-request">
  <div id="form-success" class="hidden text-center py-16 px-4 lg:px-8">
    <p
      class="text-5xl lg:text-7xl font-bold text-m-red-500 font-sans-1 leading-tight"
    >
      ¡Gracias<br />por firmar!
    </p>
    <p class="mt-6 text-m-gray-600 text-base lg:text-xl max-w-sm mx-auto">
      Tu apoyo ha sido registrado. Juntos defenderemos la prórroga.
    </p>
  </div>

  <form
    id="subscribe-form"
    method="POST"
    action="/api/subscribe"
    novalidate
    class="bg-white rounded-2xl p-4 lg:py-12 shadow-sm"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-5">
      <!-- Nombre -->
      <div class="field">
        <label for="family_name">
          Nombre <span class="req" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="family_name"
          name="family_name"
          required
          autocomplete="family-name"
          placeholder="García López"
        />
        <span class="error-msg">Por favor, introduce tu nombre.</span>
      </div>

      <!-- Email -->
      <div class="field sm:col-span-2">
        <label for="email">
          Email <span class="req" aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="ana@ejemplo.com"
        />
        <span class="error-msg">Introduce un correo electrónico válido.</span>
      </div>

      <!-- Teléfono -->
      <div class="field">
        <label for="phone">
          Teléfono <span class="req" aria-hidden="true">*</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          pattern="[0-9+\s]{9,15}"
          autocomplete="tel"
          placeholder="612 345 678"
        />
        <span class="error-msg"
          >Introduce un número válido (9 - 15 dígitos).</span
        >
      </div>

      <!-- Política de privacidad -->
      <div class="field checkbox-field sm:col-span-2">
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="privacy-check"
          />
          <label for="privacy" class="checkbox-label">
            Acepto política de privacidad
            <span class="req" aria-hidden="true">*</span>
          </label>
        </div>
        <span class="error-msg ml-7"
          >Debes aceptar la política de privacidad.</span
        >
      </div>
    </div>

    <p
      id="form-error"
      class="hidden mt-5 text-sm text-m-red-500 font-sans-1 text-center font-medium"
    >
    </p>

    <button
      type="submit"
      id="submit-btn"
      class="mt-8 w-full bg-m-blue-500 text-white font-sans-1 font-semibold text-base lg:text-l py-4 px-8 rounded-xl cursor-pointer"
    >
      Enviar
    </button>
  </form>
</div>

<style>
  /* ── Layout ── */
  .form-request {
    width: 100%;
  }

  /* ── Field wrapper ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  /* ── Label ── */
  .field > label,
  .checkbox-label {
    font-family: var(--font-sans-1);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-m-gray-900);
    line-height: 1.4;
    cursor: default;
  }

  .req {
    color: var(--color-m-red-500);
  }

  /* ── Text / email / tel / number inputs ── */
  .field input:not([type="checkbox"]) {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-m-gray-900);
    background: var(--color-white);
    border: 1.5px solid var(--color-m-gray-200);
    border-radius: 0.625rem;
    outline: none;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .field input:not([type="checkbox"])::placeholder {
    color: var(--color-m-gray-400);
  }

  .field input:not([type="checkbox"]):focus {
    border-color: var(--color-m-red-500);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-m-red-500) 12%, transparent);
  }

  /* ── :user-invalid — only fires after user interaction ── */
  .field input:not([type="checkbox"]):user-invalid {
    border-color: var(--color-m-red-500);
    background-color: color-mix(in srgb, var(--color-m-red-50) 60%, white);
  }

  .field:has(input:not([type="checkbox"]):user-invalid) .error-msg {
    display: block;
  }

  /* ── Checkbox ── */
  .privacy-check {
    width: 1.125rem;
    height: 1.125rem;
    margin-top: 0.125rem;
    flex-shrink: 0;
    accent-color: var(--color-m-red-500);
    cursor: pointer;
    border-radius: 0.25rem;
  }

  .privacy-check:user-invalid {
    outline: 2px solid var(--color-m-red-500);
    outline-offset: 2px;
  }

  .checkbox-field:has(.privacy-check:user-invalid) .error-msg {
    display: block;
  }

  .checkbox-label {
    cursor: pointer;
    color: var(--color-m-gray-700);
  }

  .checkbox-label a {
    color: var(--color-m-blue-500);
    text-decoration: underline;
  }

  .checkbox-label a:hover {
    color: var(--color-m-blue-600);
  }

  /* ── Error message ── */
  .error-msg {
    display: none;
    font-family: var(--font-sans-1);
    font-size: 0.79rem;
    color: var(--color-m-red-500);
    font-weight: 500;
  }

  /* ── Submit button ── */
  #submit-btn {
    transition:
      background-color 0.15s ease,
      opacity 0.15s ease;
  }

  #submit-btn:hover {
    background-color: color-mix(in srgb, var(--color-m-blue-500) 80%, black);
  }

  #submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
