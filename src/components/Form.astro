---
import Button from "@components/Button.astro"
---

<div class="w-full">
  <div id="form-success" class="hidden text-center py-16 px-4 lg:px-8">
    <p class="text-5xl lg:text-7xl font-bold text-m-indigo-500 leading-tight">
      ¡Gracias<br />contactar con nosotros!
    </p>
    <p class="mt-6 text-m-gray-600 text-base lg:text-xl max-w-sm mx-auto">
      Tu petición ha sido enviada. Nos pondremos en contacto contigo en breve.
    </p>
  </div>

  <form
    id="subscribe-form"
    method="POST"
    action="/api/subscribe"
    novalidate
    class="bg-white rounded-2xl p-4 lg:py-12 shadow-sm"
  >
    <div class="field flex flex-col gap-1.5 mb-6">
      <label
        for="family_name"
        class="text-sm font-medium text-m-gray-900 leading-snug cursor-default"
      >
        Nombre <span class="text-m-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="family_name"
        name="family_name"
        required
        autocomplete="family-name"
        placeholder="Ana García López"
        class="w-full py-3 px-4 font-sans text-base text-m-gray-900 bg-white border-2 border-m-gray-200 rounded-lg outline-none transition duration-150 ease-in-out"
      />
      <span class="error-msg hidden text-xs text-m-red-500 font-medium"
        >Por favor, introduce tu nombre.</span
      >
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="field flex flex-col gap-1.5">
        <label
          for="email"
          class="text-sm font-medium text-m-gray-900 leading-snug cursor-default"
        >
          Email <span class="text-m-red-500" aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="ana@ejemplo.com"
          class="w-full py-3 px-4 font-sans text-base text-m-gray-900 bg-white border-2 border-m-gray-200 rounded-lg outline-none transition duration-150 ease-in-out"
        />
        <span class="error-msg hidden text-xs text-m-red-500 font-medium"
          >Introduce un correo electrónico válido.</span
        >
      </div>

      <div class="field flex flex-col gap-1.5">
        <label
          for="phone"
          class="text-sm font-medium text-m-gray-900 leading-snug cursor-default"
        >
          Teléfono
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          pattern="[0-9+\s]{9,15}"
          autocomplete="tel"
          placeholder="612 345 678"
          class="w-full py-3 px-4 font-sans text-base text-m-gray-900 bg-white border-2 border-m-gray-200 rounded-lg outline-none transition duration-150 ease-in-out"
        />
        <span class="error-msg hidden text-xs text-m-red-500 font-medium"
          >Introduce un número válido (9 - 15 dígitos).</span
        >
      </div>

      <div class="field flex flex-col gap-1.5 sm:col-span-2">
        <label
          for="practice_type"
          class="text-sm font-medium text-m-gray-900 leading-snug cursor-default"
        >
          Tipo de práctica <span class="text-m-red-500" aria-hidden="true"
            >*</span
          >
        </label>
        <select
          id="practice_type"
          name="practice_type"
          required
          class="w-full py-3 px-4 font-sans text-base text-m-gray-900 bg-white border-2 border-m-gray-200 rounded-lg outline-none transition duration-150 ease-in-out cursor-pointer"
        >
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="independiente">Médico independiente</option>
          <option value="clinica_pequena">Clínica pequeña o mediana</option>
          <option value="grupo_clinicas">Grupo de clínicas</option>
        </select>
        <span class="error-msg hidden text-xs text-m-red-500 font-medium"
          >Por favor, selecciona el tipo de práctica.</span
        >
      </div>

      <div class="checkbox-field field flex flex-col gap-1.5 sm:col-span-2">
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="privacy-check w-4 h-4 mt-0.5 shrink-0 accent-m-indigo-500 cursor-pointer rounded"
          />
          <label
            for="privacy"
            class="text-sm font-medium text-m-gray-700 leading-snug cursor-pointer"
          >
            Acepto <a
              href="/politica-de-privacidad"
              class="underline text-m-indigo-500 hover:text-m-indigo-400"
              >política de privacidad</a
            >
            <span class="text-m-red-500" aria-hidden="true">*</span>
          </label>
        </div>
        <span class="error-msg hidden text-xs text-m-red-500 font-medium ml-7"
          >Debes aceptar la política de privacidad.</span
        >
      </div>
    </div>

    <p
      id="form-error"
      class="hidden mt-5 text-sm text-m-red-500 text-center font-medium"
    >
    </p>

    <Button type="submit" size="md" class="mt-8 w-full">Enviar</Button>
  </form>
</div>

<style>
  /* pseudo-states that cannot be expressed as inline Tailwind */
  input:not([type="checkbox"])::placeholder {
    color: var(--color-m-gray-400);
  }

  input:not([type="checkbox"]):focus,
  select:focus {
    border-color: var(--color-m-indigo-500);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-m-indigo-500) 12%, transparent);
  }

  /* :user-invalid — only fires after user interaction */
  input:not([type="checkbox"]):user-invalid,
  select:user-invalid {
    border-color: var(--color-m-red-500);
    background-color: color-mix(in srgb, var(--color-m-red-50) 60%, white);
  }

  .field:has(input:not([type="checkbox"]):user-invalid, select:user-invalid)
    .error-msg {
    display: block;
  }

  .privacy-check:user-invalid {
    outline: 2px solid var(--color-m-red-500);
    outline-offset: 2px;
  }

  .checkbox-field:has(.privacy-check:user-invalid) .error-msg {
    display: block;
  }
</style>
