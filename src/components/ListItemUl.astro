---
import { Check } from "@lucide/astro"
interface Props {
  text: string
  includeIcon?: boolean
}
const { text, includeIcon = true } = Astro.props
---

<li class="my-4">
  <div class="flex items-start gap-4 py-4">
    {
      includeIcon && (
        <div>
          <div class="size-8 bg-m-sky-500 text-m-indigo-950 rounded-full flex items-center justify-center mt-0.5">
            <Check />
          </div>
        </div>
      )
    }
    <span>{text}</span>
  </div>
</li>
