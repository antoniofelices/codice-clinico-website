---
const currentPath = Astro.url.pathname

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "nosotros" },
  { label: "Precios", href: "precios" },
]
---

<nav>
  <ul class="flex flex-col lg:flex-row gap-6 lg:gap-0 m-0">
    {
      navItems.map(({ label, href }) => {
        const isActive =
          currentPath === href || currentPath.startsWith(href + "/")
        return (
          <li>
            <a
              href={href}
              class:list={[
                "font-heading text-2xl lg:text-xs uppercase tracking-widest border-none! px-0 lg:px-3 transition-colors",
                isActive ? "text-m-red-500" : "hover:text-m-red-500",
              ]}
            >
              {label}
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>
