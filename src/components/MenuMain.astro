---
const currentPath = Astro.url.pathname

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Precios", href: "/precios" },
]
---

<nav>
  <ul class="flex flex-col lg:flex-row gap-6 lg:gap-0 m-0">
    {
      navItems.map(({ label, href }) => {
        const isActive =
          currentPath === href || currentPath.startsWith(href + "/")
        return (
          <li>
            <a
              href={href}
              class:list={[
                "font-bold text-2xl lg:text-sm border-none! px-0 lg:px-4 transition-opacity duration-150",
                isActive
                  ? "opacity-100 text-m-indigo-500"
                  : "opacity-[0.72] text-m-indigo-500 hover:opacity-100",
              ]}
            >
              {label}
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>
